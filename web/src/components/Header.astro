---
const menuItems = [
  { label: 'Bemutatkozás', href: '/#about' },
  { 
    label: 'Dekoráció', 
    href: '/gallery',
    children: [
      { label: 'Esküvők', href: '/gallery#eskuvok' },
      { label: 'Rendezvények', href: '/rendezvenyek' },
      { label: 'Katalógus', href: '/katalogus' },
      { label: 'Ajánlások', href: '/#ajanlasok' },
      { label: 'Árajánlatkérés', href: '/kapcsolat' },
      { label: 'Különleges Projektek', href: '/projektek' },
    ]
  },
  { 
    label: 'Esküvői Kisokos', 
    href: '/kisokos',
    children: [
      { label: 'Idei Trendek', href: '/kisokos#trendek' },
      { label: 'Mit kell tudnod?', href: '/kisokos#tudnivalok' },
      { label: 'Stílusok', href: '/kisokos#stilusok' },
      { label: 'Csekklista', href: '/kisokos#csekklista' },
      { label: 'Hogyan dolgozom?', href: '/kisokos#folyamat' },
    ]
  },
  { 
    label: 'Szolgáltatások', 
    href: '/szolgaltatasok',
    children: [
      { label: 'Dekoráció', href: '/gallery' },
      { label: 'Vendéglátás', href: '/vendeglatas' },
      { label: 'Bérlés', href: '/berles' },
      { label: 'Fenyőtermesztés', href: '/fenyo' },
    ]
  },
  { 
    label: 'Vendéglátás', 
    href: '/vendeglatas',
    children: [
      { label: 'Sóskút Fogadó', href: '/vendeglatas#soskut' },
      { label: '(Panzió)', href: '/vendeglatas#panzio' },
    ]
  },
  { label: 'Blog', href: '/blog' },
  { label: 'Kapcsolat', href: '/kapcsolat' },
];
---

<nav class="fixed top-0 w-full z-50 bg-white/90 backdrop-blur-sm border-b border-beige h-20 flex items-center justify-center">
  <div class="hidden lg:flex gap-8">
    {menuItems.map(item => (
      <div class="relative group h-20 flex items-center">
        <a href={item.href} class="text-xs font-semibold uppercase tracking-widest text-text-dark hover:text-terracotta transition-colors py-2">
          {item.label}
        </a>
        
        {item.children && (
          <div class="absolute top-full left-1/2 -translate-x-1/2 bg-white min-w-[220px] shadow-xl border border-beige py-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300">
            {item.children.map(child => (
              <a href={child.href} class="block px-6 py-2 text-[10px] uppercase tracking-widest text-text-muted hover:text-terracotta hover:bg-beige transition-colors text-center">
                {child.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- Mobile Menu Button -->
  <button id="mobile-menu-open" class="lg:hidden absolute left-5 text-xl p-2" aria-label="Menu megnyitása">
    <i class="fas fa-bars text-text-dark"></i>
  </button>
  
  <div class="lg:hidden font-display text-lg tracking-widest text-[#3D352E]">EVENTBOX</div>
</nav>

<!-- Mobile Overlay Menu -->
<div id="mobile-menu" class="fixed inset-0 z-[100] bg-white transform -translate-x-full transition-transform duration-500 lg:hidden">
  <div class="p-5 flex flex-col h-full">
    <div class="flex justify-between items-center mb-10">
      <div class="font-display text-lg tracking-widest">EVENTBOX</div>
      <button id="mobile-menu-close" class="text-2xl p-2" aria-label="Menu bezárása">
        <i class="fas fa-times"></i>
      </button>
    </div>
    
    <div class="flex-1 overflow-y-auto">
      <ul class="space-y-6">
        {menuItems.map(item => (
          <li class="space-y-4">
            <a href={item.href} class="mobile-link text-lg font-display uppercase tracking-widest text-text-dark block border-b border-beige pb-2">
              {item.label}
            </a>
            {item.children && (
              <ul class="pl-4 space-y-3 border-l border-beige ml-2">
                {item.children.map(child => (
                  <li>
                    <a href={child.href} class="mobile-link text-xs uppercase tracking-widest text-text-muted hover:text-terracotta">
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<div class="h-20"></div>

<script>
  const openBtn = document.getElementById('mobile-menu-open');
  const closeBtn = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  const openMenu = () => {
    menu?.classList.remove('-translate-x-full');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    menu?.classList.add('-translate-x-full');
    document.body.style.overflow = '';
  };

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  
  // Close menu when clicking a link
  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
