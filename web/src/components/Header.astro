---
const menuItems = [
  { label: 'Bemutatkozás', href: '/#about' },
  { 
    label: 'Dekoráció', 
    href: '/gallery',
    children: [
      { label: 'Esküvők', href: '/gallery#eskuvok' },
      { label: 'ZuzmóArt', href: '/zuzmo' },
      { label: 'Különleges Projektek', href: '/projektek' },
      { label: 'Ajánlások', href: '/#ajanlasok' },
      { label: 'Árajánlatkérés', href: '/kapcsolat' },
    ]
  },
  { 
    label: 'Esküvői Kisokos', 
    href: '/kisokos',
    children: [
      { label: 'Árképzés', href: '/kisokos#arak' },
      { label: 'Milyen stílusban?', href: '/kisokos#stilus' },
      { label: 'Színválasztás', href: '/kisokos#szinvalasztas' },
      { label: 'Költségvetés', href: '/kisokos#koltsegvetes' },
      { label: 'Csekklista', href: '/kisokos#csekklista' },
      { label: 'A folyamat', href: '/kisokos#folyamat' },
    ]
  },
  { 
    label: 'Sóskút Fogadó', 
    href: '/vendeglatas',
    children: [
      { label: 'A Helyszín', href: '/vendeglatas#soskut' },
      { label: 'Filozófiánk', href: '/vendeglatas#rolunk' },
      { label: 'Elhelyezkedés', href: '/vendeglatas#elhelyezkedes' },
    ]
  },
  { 
    label: 'Szolgáltatások', 
    href: '/szolgaltatasok',
    children: [
      { label: 'Dekoráció', href: '/gallery' },
      { label: 'Vendéglátás', href: '/vendeglatas' },
      { label: 'Bérlés', href: '/berles' },
      { label: 'Fenyőtermesztés', href: '/fenyo' },
    ]
  },
  { label: 'Blog', href: '/blog' },
  { label: 'Elérhetőség', href: '/kapcsolat' },
];
---

<nav class="fixed top-0 w-full z-50 bg-white/95 backdrop-blur-md border-b border-beige h-24 flex items-center shadow-sm">
  <div class="max-w-7xl mx-auto w-full px-5 flex items-center justify-between">
    
    <!-- Left Menu (Desktop) -->
    <div class="hidden lg:flex gap-8 flex-1">
      {menuItems.slice(0, 3).map(item => (
        <div class="relative group py-4">
          <a href={item.href} class="text-[10px] font-bold uppercase tracking-[0.2em] text-text-dark hover:text-terracotta transition-colors">
            {item.label}
          </a>
          {item.children && (
            <div class="absolute top-full left-0 bg-white min-w-[200px] shadow-2xl border border-beige py-6 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0">
              {item.children.map(child => (
                <a href={child.href} class="block px-8 py-2 text-[9px] uppercase tracking-widest text-text-muted hover:text-terracotta transition-colors">
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Center Logo -->
    <div class="flex-shrink-0 px-10">
      <a href="/" class="block">
        <img src="/logo.svg" alt="EventBox Decor" class="h-16 w-auto" />
      </a>
    </div>

    <!-- Right Menu (Desktop) -->
    <div class="hidden lg:flex gap-8 flex-1 justify-end">
      {menuItems.slice(3).map(item => (
        <div class="relative group py-4 text-right">
          <a href={item.href} class="text-[10px] font-bold uppercase tracking-[0.2em] text-text-dark hover:text-terracotta transition-colors">
            {item.label}
          </a>
          {item.children && (
            <div class="absolute top-full right-0 bg-white min-w-[200px] shadow-2xl border border-beige py-6 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 translate-y-2 group-hover:translate-y-0">
              {item.children.map(child => (
                <a href={child.href} class="block px-8 py-2 text-[9px] uppercase tracking-widest text-text-muted hover:text-terracotta transition-colors">
                  {child.label}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Mobile Menu Button -->
    <button id="mobile-menu-open" class="lg:hidden p-2" aria-label="Menu megnyitása">
      <i class="fas fa-bars text-xl text-text-dark"></i>
    </button>
  </div>
</nav>

<!-- Mobile Overlay Menu -->
<div id="mobile-menu" class="fixed inset-0 z-[100] bg-white transform -translate-x-full transition-transform duration-500 lg:hidden overflow-y-auto">
  <div class="p-8 flex flex-col min-h-full">
    <div class="flex justify-between items-center mb-16">
      <img src="/logo.svg" alt="EventBox Decor" class="h-12" />
      <button id="mobile-menu-close" class="p-2" aria-label="Menu bezárása">
        <i class="fas fa-times text-2xl"></i>
      </button>
    </div>
    
    <div class="flex-1">
      <ul class="space-y-8">
        {menuItems.map(item => (
          <li class="space-y-4">
            <a href={item.href} class="mobile-link text-xl font-display uppercase tracking-widest text-text-dark block">
              {item.label}
            </a>
            {item.children && (
              <ul class="pl-4 space-y-4 border-l border-beige ml-1">
                {item.children.map(child => (
                  <li>
                    <a href={child.href} class="mobile-link text-[10px] uppercase tracking-[0.2em] text-text-muted">
                      {child.label}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<div class="h-24"></div>

<script>
  const openBtn = document.getElementById('mobile-menu-open');
  const closeBtn = document.getElementById('mobile-menu-close');
  const menu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  const openMenu = () => {
    menu?.classList.remove('-translate-x-full');
    document.body.style.overflow = 'hidden';
  };

  const closeMenu = () => {
    menu?.classList.add('-translate-x-full');
    document.body.style.overflow = '';
  };

  openBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  
  mobileLinks.forEach(link => {
    link.addEventListener('click', closeMenu);
  });
</script>
