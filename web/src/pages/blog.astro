---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const posts = [
  {
    title: "Hogyan válasszuk ki az esküvői színeket?",
    excerpt: "Az esküvői színek kiválasztása nagyban befolyásolja az esemény hangulatát és stílusát. A színpaletta harmonizálja a dekorációt, a virágokat, a meghívókat...",
    date: "2025.03.15",
    image: "/images/gallery/andi-norbi (13).jpg"
  },
  {
    title: "Esküvői dekoráció költségvetése",
    excerpt: "Sokan, amikor elkezdik megálmodni az eseményük dekorációját, még nem tudják, mi minden tartozik bele, és milyen tényezők befolyásolják az árakat. Segítünk átlátni a költségeket.",
    date: "2025.02.20",
    image: "/images/ui/a dekoráció ára.jpg"
  },
  {
    title: "Hogyan zajlik az esküvői megbeszélés?",
    excerpt: "Célunk, hogy stresszmentesen, gördülékenyen haladjon a tervezés. Időpont egyeztetése után egy kérdőívvel gyűjtöm be az információkat, hogy a legtökéletesebb árajánlatot adhassam.",
    date: "2025.01.10",
    image: "/images/ui/hogyandolgozom2.jpg"
  },
  {
    title: "Miért válaszd a fenntartható dekorációt?",
    excerpt: "Nemrég elvégeztem a Virágos Masterclass képzést, ahol a fókusz a természetességre és a tűzőhabmentes technikára helyeződött. Ismerd meg miért jobb ez a természetnek.",
    date: "2024.12.05",
    image: "/images/ui/keresztelő.jpg"
  }
];
---

<Layout title="Blog | EventBox Decor">
  <Header />
  
  <main class="py-24 px-5 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-20 space-y-4 fade-in">
        <span class="text-[10px] uppercase tracking-[0.4em] text-terracotta font-semibold">Történetek & Tippek</span>
        <h1 class="text-4xl md:text-5xl font-display uppercase tracking-widest text-text-dark">Blog</h1>
        <div class="w-12 h-[1px] bg-terracotta mx-auto"></div>
        <p class="text-text-muted max-w-2xl mx-auto pt-4 italic">
            "Hasznos tippek, inspiráló történetek és kulisszatitkok az esküvők és rendezvények világából."
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
        {posts.map(post => (
          <article class="group cursor-pointer fade-in block">
            <div class="aspect-video overflow-hidden bg-beige mb-8 shadow-sm">
                <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105" />
            </div>
            <div class="space-y-4">
                <div class="flex items-center gap-4">
                    <span class="text-[10px] uppercase tracking-widest text-terracotta font-bold">{post.date}</span>
                    <div class="w-4 h-[1px] bg-beige"></div>
                </div>
                <h2 class="text-2xl font-display text-text-dark group-hover:text-terracotta transition-colors">{post.title}</h2>
                <p class="text-text-muted leading-relaxed text-sm line-clamp-3">{post.excerpt}</p>
                <div class="pt-4">
                    <span class="text-[10px] uppercase tracking-widest font-bold border-b border-terracotta pb-1 hover:text-terracotta transition-colors">Olvasd tovább →</span>
                </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</Layout>
